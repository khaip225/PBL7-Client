# FastAPI backend URL
FASTAPI_URL=http://127.0.0.1:8000

# Client identity
CLIENT_NAME=Hospital-01
CLIENT_HOST=127.0.0.1
CLIENT_MODALITY=image

# Flower server (auto-detected from modality if not set)
FLOWER_SERVER_ADDRESS=

# API Key for server authentication
CLIENT_API_KEY=your-client-api-key-here

# Prediction threshold (default: 0.5)
PREDICTION_THRESHOLD=0.5

# Heartbeat interval in seconds
HEARTBEAT_INTERVAL=30

# Local state file for dashboard
STATE_FILE=./client_state.json

# FL data directory
FL_DATA_DIR=./Local_Data/fl_data
